# User-visible data folders — keep the folder + README + .gitkeep,
# ignore the actual sermon files inside.
sources/*
!sources/.gitkeep
!sources/README.md
renders/*
!renders/.gitkeep
!renders/README.md

# Media files anywhere outside the explicitly allowed locations
*.mp4
*.mov
*.mkv
*.webm
*.m4v
*.wav
*.mp3
*.m4a
*.flac

# Allow sample(s) in examples/ and the demo asset under site/
!examples/**/*.mp4
!examples/**/*.gif
!site/**/*.mp4
!site/**/*.gif

# Intermediates / generated
# legacy folder, kept for personal curation workflow (see CLAUDE.md ritual)
edit/
**/srts/
**/tmp/
**/cache/
**/*.vtt
**/*.task                   # mediapipe models (auto-downloaded)
**/transcript.json
**/vad.json
**/cuts_proposed.json
**/propose_input.json
**/meta.json

# Per-message state (transcripts, VAD, srts — private)
memory/messages/

# Python
__pycache__/
*.pyc
*.pyo
.venv*/
.python-version
*.egg-info/

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# Per-project Claude instructions (pessoal, não commitar)
CLAUDE.md

# Build artifact: pages.yml copies scripts/install.sh into site/ at deploy time
site/install.sh

# Secrets
.env
.env.local
*.pem
*.key

# Logs
*.log
