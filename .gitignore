# Source media (large, gitignored)
sources/
*.mp4
*.mov
*.mkv
*.webm
*.m4v
*.wav
*.mp3
*.m4a
*.flac

# Allow sample(s) in examples/ and the demo asset under site/
!examples/**/*.mp4
!examples/**/*.gif
!site/**/*.mp4
!site/**/*.gif

# Intermediates / generated
edit/                       # legacy folder, will be removed
**/renders/
**/srts/
**/tmp/
**/cache/
**/*.vtt
**/*.task                   # mediapipe models (auto-downloaded)
**/transcript.json
**/vad.json
**/cuts_proposed.json
**/propose_input.json
**/meta.json

# Per-message memory (private)
memory/messages/

# Python
__pycache__/
*.pyc
*.pyo
.venv*/
.python-version
*.egg-info/

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# Per-project Claude instructions (pessoal, não commitar)
CLAUDE.md

# Build artifact: pages.yml copies scripts/install.sh into site/ at deploy time
site/install.sh

# Secrets
.env
.env.local
*.pem
*.key

# Logs
*.log
